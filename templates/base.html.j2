<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        (function() {
            var pref = localStorage.getItem("argus-theme");
            function resolve(p) {
                if (p === "light" || p === "dark") return p;
                return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            }
            document.documentElement.setAttribute("data-bs-theme", resolve(pref));
            window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function(e) {
                if (!localStorage.getItem("argus-theme")) {
                    document.documentElement.setAttribute("data-bs-theme", e.matches ? "dark" : "light");
                    if (typeof updateThemeIcon === "function") updateThemeIcon();
                }
            });
            window.applyTheme = function() {
                var p = localStorage.getItem("argus-theme");
                document.documentElement.setAttribute("data-bs-theme", resolve(p));
                updateThemeIcon();
            };
            window.cycleTheme = function() {
                var current = localStorage.getItem("argus-theme");
                var next = current === null ? "light" : current === "light" ? "dark" : null;
                if (next) { localStorage.setItem("argus-theme", next); }
                else { localStorage.removeItem("argus-theme"); }
                applyTheme();
            };
            window.updateThemeIcon = function() {
                var p = localStorage.getItem("argus-theme");
                var icon = document.getElementById("theme-icon");
                var label = document.getElementById("theme-label");
                if (icon) icon.className = "fas " + (p === null ? "fa-circle-half-stroke" : p === "light" ? "fa-sun" : "fa-moon");
                if (label) label.textContent = p === null ? "Auto" : p === "light" ? "Light" : "Dark";
            };
        })();
    </script>
    <title>Argus - {%block title%}{%endblock%}</title>
    <link rel="stylesheet" href="/s/dist/styles.css">
    <link rel="shortcut icon" href="/s/argus.png" type="image/png">
    {% block javascripts %}
    <script>
        var globalFlashes = {{ get_flashed_messages(with_categories=true) | tojson | safe }};
    </script>
    {% if g.user %}
    <script>
        var gArgusCurrentUser = {{ g.user | safe_user | tojson | safe }};
    </script>
    {% endif %}
    <script src="/s/dist/fontAwesome.bundle.js"></script>
    <script type="module" src="/s/dist/main.bundle.js"></script>
    <script type="module" src="/s/dist/globalAlert.bundle.js"></script>
    <script type="module" defer src="/s/dist/notificationCounter.bundle.js"></script>
    {% endblock javascripts %}
</head>
<body class="bg-lighter">
    <div class="app d-flex flex-column min-vh-100">
        {% include "partials/nav_bar.html.j2" %}
        <div id="argusErrors">
        </div>
        <div id="argusMain" class="container-fluid">
            {% block body %}
            {% endblock %}
        </div>
        <div id="argusFooter" class="mt-auto container-fluid bg-dark text-center text-light fw-light fs-6 p-4">
        Argus
        </div>
    </div>
</body>
</html>
